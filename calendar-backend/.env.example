NODE_ENV=development
PORT=3001
POSTGRES_PASSWORD=calendar_local_password
DATABASE_URL=postgres://calendar_user:calendar_local_password@localhost:5432/calendar_db
JWT_SECRET=replace-with-a-long-random-secret
CSRF_SECRET=replace-with-another-long-random-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_ORIGIN=http://localhost:5173
AUTH_RATE_LIMIT_MAX=10
GLOBAL_RATE_LIMIT_MAX=120
SENSITIVE_RATE_LIMIT_MAX=5
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
VERIFICATION_TOKEN_TTL_HOURS=24
RESET_TOKEN_TTL_MINUTES=60
LOCKOUT_ATTEMPTS=5
LOCKOUT_MINUTES=15
COOKIE_SECURE=false
MAIL_MODE=log
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Calendar Budget <no-reply@example.com>
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=30000
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=10000
DB_SSL=false
TRUST_PROXY_HOPS=0
SHUTDOWN_TIMEOUT_MS=10000
REQUEST_TIMEOUT_MS=15000
HEADERS_TIMEOUT_MS=10000
KEEP_ALIVE_TIMEOUT_MS=5000
WORKER_POLL_INTERVAL_MS=1000
